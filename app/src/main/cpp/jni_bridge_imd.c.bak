/*
 * jni_bridge_imd.c
 * JNI bridge cho libimobiledevice trên Android
 */

#include <jni.h>
#include <string.h>
#include <stdlib.h>
#include <stdio.h>
#include <unistd.h>
#include <pthread.h>
#include "usbmuxd_server.h"
#include "usb_fd_bridge.h"
#include "android_usbmuxd_fix.h"

#define TAG "JNI_IMD"

static JavaVM *g_jvm = NULL;
static jobject g_thiz = NULL;
static jmethodID g_midLog = NULL;
static jmethodID g_midNotify = NULL;
static pthread_mutex_t g_jni_mutex = PTHREAD_MUTEX_INITIALIZER;

static char g_udid[64] = {0};
static int  g_product_id = 0;

/* ========== JNI Helpers ========== */
static JNIEnv *attach_env(void) {
    JNIEnv *env = NULL;
    if ((*g_jvm)->GetEnv(g_jvm, (void **)&env, JNI_VERSION_1_6) == JNI_OK)
        return env;
    (*g_jvm)->AttachCurrentThread(g_jvm, &env, NULL);
    return env;
}

static void detach_env(void) {
    (*g_jvm)->DetachCurrentThread(g_jvm);
}

/* ========== Callbacks to Java ========== */
void android_usbmuxd_fix_log(const char *msg) {
    if (!g_jvm || !g_thiz || !g_midLog) return;
    pthread_mutex_lock(&g_jni_mutex);
    JNIEnv *env = attach_env();
    jstring jmsg = (*env)->NewStringUTF(env, msg);
    (*env)->CallVoidMethod(env, g_thiz, g_midLog, jmsg);
    (*env)->DeleteLocalRef(env, jmsg);
    pthread_mutex_unlock(&g_jni_mutex);
}

void android_usbmuxd_fix_notify(int event, const char *udid) {
    if (!g_jvm || !g_thiz || !g_midNotify) return;
    pthread_mutex_lock(&g_jni_mutex);
    JNIEnv *env = attach_env();
    jstring judid = udid ? (*env)->NewStringUTF(env, udid) : NULL;
    (*env)->CallVoidMethod(env, g_thiz, g_midNotify, event, judid);
    if (judid) (*env)->DeleteLocalRef(env, judid);
    pthread_mutex_unlock(&g_jni_mutex);
}

void android_usbmuxd_fix_set_device(const char *udid, int product_id) {
    strncpy(g_udid, udid, sizeof(g_udid) - 1);
    g_product_id = product_id;
}

/* ========== JNI Exported ========== */
JNIEXPORT jint JNICALL JNI_OnLoad(JavaVM *vm, void *reserved) {
    (void)reserved;
    g_jvm = vm;
    return JNI_VERSION_1_6;
}

JNIEXPORT void JNICALL
Java_com_sideloadtool_usbmuxd_NativeBridge_nativeInit(
    JNIEnv *env, jobject thiz) {
    g_thiz = (*env)->NewGlobalRef(env, thiz);
    jclass cls = (*env)->GetObjectClass(env, thiz);
    g_midLog = (*env)->GetMethodID(env, cls, "onNativeLog", "(Ljava/lang/String;)V");
    g_midNotify = (*env)->GetMethodID(env, cls, "onNativeEvent", "(ILjava/lang/String;)V");
}

JNIEXPORT void JNICALL
Java_com_sideloadtool_usbmuxd_NativeBridge_nativeSetDevice(
    JNIEnv *env, jobject thiz,
    jstring jUdid, jint productId) {
    (void)thiz;
    const char *udid = (*env)->GetStringUTFChars(env, jUdid, NULL);
    android_usbmuxd_fix_set_device(udid, productId);
    (*env)->ReleaseStringUTFChars(env, jUdid, udid);
}

JNIEXPORT jboolean JNICALL
Java_com_sideloadtool_usbmuxd_NativeBridge_nativeStartServer(
    JNIEnv *env, jobject thiz,
    jstring jFilesDir, jstring jUdid, jint productId) {
    (void)thiz;
    const char *filesDir = (*env)->GetStringUTFChars(env, jFilesDir, NULL);
    const char *udid = jUdid ? (*env)->GetStringUTFChars(env, jUdid, NULL) : NULL;
    int r = usbmuxd_server_start(filesDir, udid, productId);
    if (udid) (*env)->ReleaseStringUTFChars(env, jUdid, udid);
    (*env)->ReleaseStringUTFChars(env, jFilesDir, filesDir);
    return r ? JNI_TRUE : JNI_FALSE;
}

JNIEXPORT void JNICALL
Java_com_sideloadtool_usbmuxd_NativeBridge_nativeStopServer(
    JNIEnv *env, jobject thiz) {
    (void)env;
    (void)thiz;
    usbmuxd_server_stop();
}

JNIEXPORT jstring JNICALL
Java_com_sideloadtool_usbmuxd_NativeBridge_nativeGetSocketPath(
    JNIEnv *env, jobject thiz) {
    (void)thiz;
    return (*env)->NewStringUTF(env, usbmuxd_server_socket_path());
}

JNIEXPORT jint JNICALL
Java_com_sideloadtool_usbmuxd_NativeBridge_nativeUsbBridgeInit(
    JNIEnv *env, jobject thiz, jint usbFd) {
    (void)env;
    (void)thiz;
    return usb_bridge_init(usbFd);
}

JNIEXPORT void JNICALL
Java_com_sideloadtool_usbmuxd_NativeBridge_nativeUsbBridgeCleanup(
    JNIEnv *env, jobject thiz) {
    (void)env;
    (void)thiz;
    usb_bridge_cleanup();
}

JNIEXPORT jboolean JNICALL
Java_com_sideloadtool_usbmuxd_NativeBridge_nativeUsbBridgeClearHalt(
    JNIEnv *env, jobject thiz) {
    (void)env;
    (void)thiz;
    return usb_bridge_clear_endpoints_halt() ? JNI_TRUE : JNI_FALSE;
}
