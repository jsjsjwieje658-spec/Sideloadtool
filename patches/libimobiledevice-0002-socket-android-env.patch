From: SideloadTool Android Fix <fix@sideload.tool>
Date: Sat, 19 Jul 2026 04:30:00 +0700
Subject: [PATCH 2/2] socket: fix usbmuxd_connect() to read USBMUXD_SOCKET_ADDRESS on Android

On Android (especially non-root), the default usbmuxd socket path
/var/run/usbmuxd does not exist. The USBMUXD_SOCKET_ADDRESS env var
points to either a Unix socket path or a TCP endpoint (host:port).

This patch ensures usbmuxd_connect() checks USBMUXD_SOCKET_ADDRESS
and USBMUXD_SOCKET_PATH before falling back to the default path.
It also adds support for TCP connections (host:port format),
which is required for compatibility with Rust-based usbmuxd tools
and some Android setups.

--- a/common/socket.c
+++ b/common/socket.c
@@ -55,6 +55,10 @@
 #include <sys/un.h>
 #endif

+#ifdef __ANDROID__
+#include <ctype.h>
+#endif
+
 #ifndef EAFNOSUPPORT
 #define EAFNOSUPPORT 102
 #endif
@@ -476,6 +480,88 @@ int socket_connect_addr(struct sockaddr* addr, uint16_t port)
 	return sfd;
 }

+#ifdef __ANDROID__
+/**
+ * FIX: Parse USBMUXD_SOCKET_ADDRESS env var on Android.
+ * Supports two formats:
+ *   - Unix socket: /data/.../usbmuxd.sock
+ *   - TCP:         127.0.0.1:27015
+ */
+static int socket_connect_usbmuxd_android(void)
+{
+	const char *addr_env = getenv("USBMUXD_SOCKET_ADDRESS");
+	if (!addr_env) addr_env = getenv("USBMUXD_SOCKET_PATH");
+	if (!addr_env) return -1;
+
+	/* Check if it's TCP (contains ':') and not a Unix path */
+	const char *colon = strrchr(addr_env, ':');
+	if (colon && colon > addr_env) {
+		/* Verify it's not just a Unix path with colon in name */
+		int is_tcp = 1;
+		for (const char *p = colon + 1; *p; p++) {
+			if (!isdigit((unsigned char)*p)) {
+				is_tcp = 0;
+				break;
+			}
+		}
+		if (is_tcp) {
+			char host[128];
+			int port;
+			int host_len = colon - addr_env;
+			if (host_len >= sizeof(host)) host_len = sizeof(host) - 1;
+			memcpy(host, addr_env, host_len);
+			host[host_len] = '\0';
+			port = atoi(colon + 1);
+			if (port > 0) {
+				return socket_connect(host, port);
+			}
+		}
+	}
+
+	/* Unix socket */
+	struct sockaddr_un addr;
+	memset(&addr, 0, sizeof(addr));
+	addr.sun_family = AF_UNIX;
+	strncpy(addr.sun_path, addr_env, sizeof(addr.sun_path) - 1);
+
+	int sfd = socket(AF_UNIX, SOCK_STREAM, 0);
+	if (sfd < 0) return -1;
+
+	int flags = fcntl(sfd, F_GETFL, 0);
+	if (flags >= 0) fcntl(sfd, F_SETFL, flags | O_NONBLOCK);
+
+	if (connect(sfd, (struct sockaddr *)&addr, sizeof(addr)) < 0) {
+		if (errno == EINPROGRESS) {
+			fd_set fds;
+			FD_ZERO(&fds);
+			FD_SET(sfd, &fds);
+			struct timeval tv = { .tv_sec = 5, .tv_usec = 0 };
+			if (select(sfd + 1, NULL, &fds, NULL, &tv) > 0) {
+				int so_error;
+				socklen_t len = sizeof(so_error);
+				getsockopt(sfd, SOL_SOCKET, SO_ERROR, &so_error, &len);
+				if (so_error == 0) {
+					fcntl(sfd, F_SETFL, flags);
+					return sfd;
+				}
+			}
+		}
+		close(sfd);
+		return -1;
+	}
+	fcntl(sfd, F_SETFL, flags);
+	return sfd;
+}
+#endif /* __ANDROID__ */
+
 int socket_create_unix(const char *filename)
 {
 #ifdef WIN32
@@ -560,6 +646,15 @@ int socket_connect_unix(const char *filename)

 int socket_connect_usbmuxd(void)
 {
+#ifdef __ANDROID__
+	/* FIX: Try Android-specific env var first */
+	int sfd = socket_connect_usbmuxd_android();
+	if (sfd >= 0) {
+		return sfd;
+	}
+	/* Fall through to default path if env var not set or failed */
+#endif
+
 #ifdef WIN32
 	return socket_connect("127.0.0.1", 27015);
 #else
